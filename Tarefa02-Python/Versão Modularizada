def ler_produto(indice):

    print(f"\nProduto {indice + 1}")

    nome = input("Nome do produto: ")
    quantidade = int(input("Quantidade: "))
    preco = float(input("Preço unitário: R$ "))

    return nome, quantidade, preco


def calcular_subtotal(quantidade, preco):

    return quantidade * preco


def calcular_desconto(total):

    if total > 500:
        return total * 0.10
    elif total > 200:
        return total * 0.05
    else:
        return 0


def calcular_total(subtotal, desconto):

    return subtotal - desconto


def imprimir_cupom(produtos, subtotal_geral, desconto, total_final):

    print("\n========== CUPOM ==========")

    for produto in produtos:

        print(f"Produto: {produto['nome']}")
        print(f"Quantidade: {produto['quantidade']}")
        print(f"Preço Unitário: R$ {produto['preco']:.2f}")
        print(f"Subtotal: R$ {produto['subtotal']:.2f}")
        print("---------------------------")

    print(f"Subtotal Geral: R$ {subtotal_geral:.2f}")
    print(f"Desconto: R$ {desconto:.2f}")
    print(f"Total Final: R$ {total_final:.2f}")


produtos = []
subtotal_geral = 0

for i in range(3):

    nome, quantidade, preco = ler_produto(i)

    subtotal = calcular_subtotal(quantidade, preco)

    produtos.append({
        "nome": nome,
        "quantidade": quantidade,
        "preco": preco,
        "subtotal": subtotal
    })

    subtotal_geral += subtotal

desconto = calcular_desconto(subtotal_geral)

total_final = calcular_total(subtotal_geral, desconto)

imprimir_cupom(produtos, subtotal_geral, desconto, total_final)
