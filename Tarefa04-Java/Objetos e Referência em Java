class Produto {

    String nome;
    double preco;
}

public class ObjetosReferencia {

    public static void aplicarDesconto(Produto p) {

        System.out.println("\nDentro do método - antes do desconto:");
        System.out.println("Produto: " + p.nome);
        System.out.println("Preço: R$ " + p.preco);

        p.preco = p.preco * 0.90;

        System.out.println("\nDentro do método - depois do desconto:");
        System.out.println("Produto: " + p.nome);
        System.out.println("Preço: R$ " + p.preco);
    }

    public static void main(String[] args) {

        Produto produto = new Produto();

        produto.nome = "Notebook";
        produto.preco = 3500.00;

        System.out.println("No main - antes da chamada:");
        System.out.println("Produto: " + produto.nome);
        System.out.println("Preço: R$ " + produto.preco);

        aplicarDesconto(produto);

        System.out.println("\nNo main - depois da chamada:");
        System.out.println("Produto: " + produto.nome);
        System.out.println("Preço: R$ " + produto.preco);
    }
}
